  .dot {
    transition: fill 0.3s ease-in-out, filter 0.3s ease-in-out;
  }

  .idle .dot {
    fill: var(--ds-gray-800);
    animation: none;
    filter: drop-shadow(0 0 0 transparent);
  }

  .fade .dot {
    fill: var(--ds-gray-alpha-500);
  }
  .fade .dot-1 { animation: fadeGray 0.9s ease-in-out infinite 0s; }
  .fade .dot-3 { animation: fadeGray 0.9s ease-in-out infinite 0.1s; }
  .fade .dot-6 { animation: fadeGray 0.9s ease-in-out infinite 0.2s; }
  .fade .dot-10 { animation: fadeGray 0.9s ease-in-out infinite 0.3s; }
  .fade .dot-9 { animation: fadeGray 0.9s ease-in-out infinite 0.4s; }
  .fade .dot-8 { animation: fadeGray 0.9s ease-in-out infinite 0.5s; }
  .fade .dot-7 { animation: fadeGray 0.9s ease-in-out infinite 0.6s; }
  .fade .dot-4 { animation: fadeGray 0.9s ease-in-out infinite 0.7s; }
  .fade .dot-2 { animation: fadeGray 0.9s ease-in-out infinite 0.8s; }
  .fade .dot-5 { fill: var(--ds-gray-200); animation: none; }

  @keyframes fadeGray {
    0%, 80%, 100% {
      fill: var(--ds-gray-alpha-600);
    }
    40% {
      fill: var(--ds-gray-alpha-900);
    }
  }

  .ripple .dot {
    fill: var(--ds-gray-alpha-500);
    animation: rippleGray 2s infinite 0s;
    animation-timing-function: ease-in-out;

  }
  .ripple .dot-5 { animation-delay: 0s; }
  .ripple .dot-4,
  .ripple .dot-6 { animation-delay: 0.16s; }
  .ripple .dot-2,
  .ripple .dot-3,
  .ripple .dot-8,
  .ripple .dot-9 { animation-delay: 0.3s; }
  .ripple .dot-1,
  .ripple .dot-7,
  .ripple .dot-10 { animation-delay: 0.41s;  animation-timing-function: cubic-bezier(.58,0,.38,.98) }

  @keyframes rippleGray {
    0%, 60%, 100% {
      fill: var(--ds-gray-alpha-400);
      filter: drop-shadow(0 0 0 transparent);
    }
    30% {
      fill: var(--ds-gray-alpha-1000);
      filter: drop-shadow(0 0 1.5px rgba(23, 23, 23, 0.2));
    }
  }

  .success .dot-4,
  .success .dot-8,
  .success .dot-5,
  .success .dot-3 {
    fill: var(--ds-blue-700);
    filter: none;
  }
  .success .dot-4 { animation: successBlue 0.3s ease-in-out forwards 0s; }
  .success .dot-8 { animation: successBlue 0.3s ease-in-out forwards 0.05s; }
  .success .dot-5 { animation: successBlue 0.3s ease-in-out forwards 0.1s; }
  .success .dot-3 { animation: successBlue 0.3s ease-in-out forwards 0.15s; }

  .success .dot-6,
  .success .dot-2,
  .success .dot-9,
  .success .dot-1,
  .success .dot-7,
  .success .dot-10 {
    fill: var(--ds-blue-200);
    filter: none;
  }
  .success .dot-6 { animation: successLightBlue 0.3s ease-in-out forwards 0.03s; }
  .success .dot-2 { animation: successLightBlue 0.3s ease-in-out forwards 0.08s; }
  .success .dot-9 { animation: successLightBlue 0.3s ease-in-out forwards 0.13s; }
  .success .dot-1 { animation: successLightBlue 0.3s ease-in-out forwards 0.18s; }
  .success .dot-7 { animation: successLightBlue 0.3s ease-in-out forwards 0.18s; }
  .success .dot-10 { animation: successLightBlue 0.3s ease-in-out forwards 0.18s; }

  @keyframes successBlue {
    0% {
      fill: var(--ds-gray-alpha-400);
    }
    100% {
      fill: var(--ds-blue-700);
    }
  }

  @keyframes successLightBlue {
    0% {
      fill: var(--ds-gray-alpha-400);
    }
    100% {
      fill: var(--ds-blue-200);
