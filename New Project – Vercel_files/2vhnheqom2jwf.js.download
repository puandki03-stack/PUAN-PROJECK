from dotenv import load_dotenv
from vercel.sandbox import AsyncSandbox as Sandbox

load_dotenv('.env.local')

async def main() -> None:
    sandbox = await Sandbox.create()

    cmd = await sandbox.run_command(
        "echo",
        ["Hello from Vercel Sandbox!"]
    )
    stdout = await cmd.stdout()
    print(f"Message: {stdout}")

    await sandbox.stop()

if __name__ == "__main__":
    asyncio.run(main())`},c=[{value:"nodejs",title:"Node.js"},{value:"python",title:"Python"}],u={nodejs:"javascript",python:"python"};function p(){let[e,n]=(0,o.useState)("nodejs"),i=d[e],p=u[e];return(0,t.jsxs)("div",{className:"relative w-full flex-1 rounded-md shadow-sm overflow-hidden",children:[(0,t.jsxs)("div",{className:"flex items-center justify-between bg-background-200 border-b border-gray-400 rounded-t-md p-2 h-12",children:[(0,t.jsx)("div",{className:"flex relative items-center gap-2 text-gray-900 text-sm px-2",children:(0,t.jsx)(a.Tabs,{selected:e,setSelected:e=>n(e),tabClassName:"text-xs md:text-sm whitespace-nowrap !font-sans",tabs:c})}),(0,t.jsx)(r.CopyButton,{textToCopy:i,label:"Copy code",shape:"square",size:"small",type:"tertiary",className:"!text-gray-900"})]}),(0,t.jsx)("div",{className:"h-full w-full bg-background-100 relative overflow-auto max-h-[245px]",children:(0,t.jsx)(s.default,{...s.defaultProps,code:i,language:p,theme:void 0,children:e=>{let{tokens:r,getLineProps:a,getTokenProps:n}=e;return(0,t.jsxs)("div",{className:"w-full py-3 px-3 flex gap-5 text-copy-13-mono",children:[(0,t.jsx)("ul",{className:"text-gray-600 select-none text-right w-4 relative list-none m-0 p-0 pt-px",children:r.map((e,r)=>(0,t.jsx)("li",{className:"h-5",children:r+1},r))}),(0,t.jsx)("pre",{className:`relative w-full my-0 py-0 !text-copy-13-mono ${l.default.pre}`,children:(0,t.jsx)("code",{className:l.default.code,children:r.map((e,r)=>{let{key:i,...o}=a({line:e,key:r});return(0,t.jsx)("div",{...o,className:l.default.row,children:e.map((e,r)=>{let{key:a,...i}=n({token:e,key:r});return(0,t.jsx)("span",{...i},a)})},i)})})})]})}})})]})}function m(){return(0,t.jsxs)("div",{className:"isolate",children:[(0,t.jsxs)("div",{className:"material-base flex flex-col @lg-page:flex-row items-start justify-between rounded-lg p-6 gap-8 relative z-10",children:[(0,t.jsxs)("div",{className:"flex flex-col items-stretch justify-start @lg-page:justify-between flex-initial gap-6 @lg-p